import { Component } from '@angular/core';

import { CommonModule } from '@angular/common';
import { HttpClient } from '@angular/common/http';
import { HttpParams } from '@angular/common/http';

@Component({
  selector: 'app-comp1',
  standalone: true,
  imports: [CommonModule],
  templateUrl: './comp1.component.html',
  styleUrl: './comp1.component.css',
})
export class Comp1Component {
  users: any[] = [];

  constructor(private http: HttpClient) {}

  ngOnInit(): void {
    this.loadUsers('asc');
  }

  loadUsers(order: string) {
    const params = new HttpParams().set('_sort', 'name').set('_order', order);

    this.http
      .get<any[]>('https://jsonplaceholder.typicode.com/users', { params })
      .subscribe((res) => {
        this.users = res;
      });
  }
}


<button (click)="loadUsers('asc')">
    Ascending
</button>

<button (click)="loadUsers('desc')">
    Descending
</button>

<hr>

@for(user of users; track user.id){

<p>{{user.name}}</p>

}
