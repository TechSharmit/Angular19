<!--
This is our custom input field
-->

<!-- When user clicks the input and then leaves it, blur event happens. We call onTouched() so
    Angular knows that the user has interacted with this control. -->

<input [value]="value" (blur)="onTouched()" placeholder="Type something">

import { Component, forwardRef, Input } from '@angular/core';
import { NG_VALUE_ACCESSOR } from '@angular/forms';

@Component({
  selector: 'app-comp1',
  imports: [],
  templateUrl: './comp1.component.html',
  styleUrl: './comp1.component.css',

  // This tells Angular that this component will behave like a form control

  providers: [
    {
      provide: NG_VALUE_ACCESSOR,
      useExisting: forwardRef(() => Comp1Component),
      multi: true,
    },
  ],
})
export class Comp1Component {

  // This variable will store the value coming from the form

  value = '';

  // Angular will give us functions here

  // We will store them and call them when needed

  onChange: any = () => {};
  onTouched: any = () => {};

  // Angular calls this when it wants to write a value into the input

  writeValue(val: string): void {
    this.value = val;
  }

  // Angular gives us a function that we call when value changes

  registerOnChange(fn: any): void {
    this.onChange = fn;
  }

  // Angular gives us a function that we call when the control is touched
  
  registerOnTouched(fn: any): void {
    this.onTouched = fn;
  }
}
